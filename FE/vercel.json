{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://aira-healthcare-api.onrender.com/api/$1"
        },
        {
            "source": "/health",
            "destination": "https://aira-healthcare-api.onrender.com/health"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}