# AIRA Healthcare — Environment Variables Reference
# ─────────────────────────────────────────────────
# NEVER commit your real .env file to Git.
# Copy this file as .env and fill in real values.
#
# For Render deployment: add these as Environment Variables
# in the Render dashboard (Dashboard → Service → Environment)

# ── Database ──────────────────────────────────────────────────────
# Get from: Supabase → Project Settings → Database → Connection string (URI mode)
# Format:   postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── Auth (JWT) ────────────────────────────────────────────────────
# Generate a strong random secret (256-bit):
#   python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: Do NOT use a JWT token as this value — use a raw secret string!
JWT_SECRET_KEY=generate-a-real-256-bit-secret-here

# ── HuggingFace ──────────────────────────────────────────────────
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# ── AI Model Config ──────────────────────────────────────────────
# For Render free tier (512MB RAM), use "tiny"
# For paid/local, use "small" or "medium" for better accuracy
WHISPER_MODEL_SIZE=tiny

# Cache directory for Whisper model download
WHISPER_CACHE_DIR=/tmp/.model_cache/whisper

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# After deploying to Vercel, set this to your Vercel URL
# Example: https://aira-healthcare.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
